server.port=8081

db.url=jdbc:mysql://localhost:3306/stock_trade_management?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
db.user=root
db.password=

# Set true when connecting to central-trading.
central.enabled=false
central.api-base=http://localhost:8082

auth.token-minutes=30

# Account system integration is disabled by default.
# Put real staff credentials only in local config.properties.
account.enabled=false
account.api-base=http://localhost:8080
account.staff-username=
account.staff-password=
